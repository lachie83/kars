      "gridPos": {
        "h": 4,
        "w": 4,
        "x": 8,
        "y": 1
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "targets": [
        {
          "expr": "sum(rate(azureclaw_inference_requests_total{status!=\"ok\",sandbox=~\"$sandbox\"}[5m])) / clamp_min(sum(rate(azureclaw_inference_requests_total{sandbox=~\"$sandbox\"}[5m])), 1) * 100",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "decimals": 2,
          "thresholds": {
            "mode": "absolute",
