[0.201, "o", "\u001b[34m?\u001b[39m \u001b[1mWhich inference provider do you want to use?\u001b[22m\r\n  GitHub Copilot                    (recommended; needs an active Copilot seat — large context,\r\nClaude/GPT/Gemini)\r\n\u001b[36m❯ Azure AI Foundry / Azure OpenAI   (full feature set: Memory Store, agents, Content Safety, etc.)\u001b[39m\r\n  GitHub Models                     (free; just need a GitHub PAT — small context, Foundry features\r\ndisabled)\r\n\r\n\u001b[1m↑↓\u001b[22m \u001b[2mnavigate\u001b[22m\u001b[2m • \u001b[22m\u001b[1m⏎\u001b[22m \u001b[2mselect\u001b[22m\u001b[?25l\u001b[23G"]
[1.597, "o", "\u001b[2K\u001b[1A\u001b[2K\u001b[1A\u001b[2K\u001b[1A\u001b[2K\u001b[1A\u001b[2K\u001b[1A\u001b[2K\u001b[1A\u001b[2K\u001b[1A\u001b[2K\u001b[G\u001b[34m?\u001b[39m \u001b[1mWhich inference provider do you want to use?\u001b[22m\r\n\u001b[36m❯ GitHub Copilot                    (recommended; needs an active Copilot seat — large context, \u001b[39m\r\n\u001b[36mClaude/GPT/Gemini)\u001b[39m\r\n  Azure AI Foundry / Azure OpenAI   (full feature set: Memory Store, agents, Content Safety, etc.)\r\n  GitHub Models                     (free; just need a GitHub PAT — small context, Foundry features\r\ndisabled)\r\n\r\n\u001b[1m↑↓\u001b[22m \u001b[2mnavigate\u001b[22m\u001b[2m • \u001b[22m\u001b[1m⏎\u001b[22m \u001b[2mselect\u001b[22m\u001b[?25l\u001b[23G"]
