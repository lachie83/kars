    { "type": "rectangle", "id": "sre", "x": 950, "y": 190, "width": 400, "height": 320, "strokeColor": "#5C2D91", "backgroundColor": "transparent", "fillStyle": "solid", "strokeWidth": 3, "roundness": { "type": 3 } },
    { "type": "rectangle", "id": "sre_hdr", "x": 950, "y": 190, "width": 400, "height": 44, "strokeColor": "#5C2D91", "backgroundColor": "#5C2D91", "fillStyle": "solid", "strokeWidth": 2, "roundness": { "type": 3 }, "boundElements": [{"type": "text", "id": "sre_hdr_t"}] },
    { "type": "text", "id": "sre_hdr_t", "x": 960, "y": 200, "width": 380, "height": 24, "text": "🩺  KARS-SRE  ·  the cluster's own SRE agent", "fontSize": 16, "fontFamily": 1, "strokeColor": "#ffffff", "textAlign": "center", "verticalAlign": "middle", "containerId": "sre_hdr" },

    { "type": "text", "id": "sre_d1", "x": 970, "y": 254, "width": 360, "height": 28, "text": "Built-in operator agent — installed by:", "fontSize": 14, "fontFamily": 1, "strokeColor": "#000000", "textAlign": "left", "verticalAlign": "top" },
    { "type": "rectangle", "id": "sre_cli", "x": 970, "y": 286, "width": 240, "height": 32, "strokeColor": "#5C2D91", "backgroundColor": "#E8DAEF", "fillStyle": "solid", "strokeWidth": 1, "roundness": { "type": 3 }, "boundElements": [{"type": "text", "id": "sre_cli_t"}] },
    { "type": "text", "id": "sre_cli_t", "x": 980, "y": 294, "width": 220, "height": 16, "text": "kars sre install", "fontSize": 14, "fontFamily": 3, "strokeColor": "#000000", "textAlign": "center", "verticalAlign": "middle", "containerId": "sre_cli" },

    { "type": "text", "id": "sre_p1", "x": 970, "y": 336, "width": 360, "height": 25, "text": "READ:   cluster-wide (kars CRs +", "fontSize": 13, "fontFamily": 1, "strokeColor": "#000000", "textAlign": "left", "verticalAlign": "top" },
    { "type": "text", "id": "sre_p1b", "x": 970, "y": 358, "width": 360, "height": 25, "text": "             apiextensions + workloads)", "fontSize": 13, "fontFamily": 1, "strokeColor": "#000000", "textAlign": "left", "verticalAlign": "top" },
    { "type": "text", "id": "sre_p2", "x": 970, "y": 390, "width": 360, "height": 25, "text": "WRITE:  gated by one-shot approval", "fontSize": 13, "fontFamily": 1, "strokeColor": "#000000", "textAlign": "left", "verticalAlign": "top" },
    { "type": "text", "id": "sre_p3", "x": 970, "y": 422, "width": 360, "height": 25, "text": "NOT on the mesh · NO sub-agents", "fontSize": 13, "fontFamily": 1, "strokeColor": "#000000", "textAlign": "left", "verticalAlign": "top" },

    { "type": "text", "id": "sre_cli2", "x": 970, "y": 460, "width": 360, "height": 22, "text": "kars sre talk / diagnose / approve", "fontSize": 13, "fontFamily": 3, "strokeColor": "#000000", "textAlign": "left", "verticalAlign": "top" },

