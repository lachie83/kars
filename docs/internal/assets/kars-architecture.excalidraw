{
  "type": "excalidraw",
  "version": 2,
  "source": "claude",
  "elements": [

    { "type": "text", "id": "title", "x": 80, "y": 30, "width": 1240, "height": 50, "text": "kars — Agent Reference Stack for Kubernetes", "fontSize": 36, "fontFamily": 1, "strokeColor": "#000000", "textAlign": "left", "verticalAlign": "top" },

    { "type": "text", "id": "subtitle", "x": 80, "y": 80, "width": 1240, "height": 35, "text": "One sandbox · one agent · one trust boundary · one per-sandbox Entra Agent ID", "fontSize": 18, "fontFamily": 1, "strokeColor": "#000000", "textAlign": "left", "verticalAlign": "top" },

    { "type": "rectangle", "id": "cluster", "x": 60, "y": 140, "width": 1320, "height": 720, "strokeColor": "#495057", "backgroundColor": "transparent", "fillStyle": "solid", "strokeWidth": 2, "strokeStyle": "dashed", "roundness": { "type": 3 } },

