    { "type": "text", "id": "pod_banner_t", "x": 100, "y": 552, "width": 800, "height": 22, "text": "⬢  POD SANDBOXING  ·  opt in per sandbox with  spec.isolation: confidential  →  Kata + AMD SEV-SNP VM-level isolation", "fontSize": 14, "fontFamily": 1, "strokeColor": "#ffffff", "textAlign": "center", "verticalAlign": "middle", "containerId": "pod_banner" },

