    { "type": "rectangle", "id": "agt_strip", "x": 90, "y": 690, "width": 10, "height": 80, "strokeColor": "#5C2D91", "backgroundColor": "#5C2D91", "fillStyle": "solid", "strokeWidth": 0, "roundness": { "type": 3 } },
    { "type": "text", "id": "agt_title", "x": 120, "y": 700, "width": 1220, "height": 30, "text": "Microsoft Agent Governance Toolkit (AGT)  —  consumed, never re-implemented", "fontSize": 18, "fontFamily": 1, "strokeColor": "#000000", "textAlign": "left", "verticalAlign": "top" },
    { "type": "text", "id": "agt_sub", "x": 120, "y": 732, "width": 1220, "height": 25, "text": "PolicyDecisionProvider · AuditSink · SigningProvider · MeshProvider  ·  hash-chained audit · per-peer trust · behaviour monitoring · rate-limit", "fontSize": 13, "fontFamily": 1, "strokeColor": "#000000", "textAlign": "left", "verticalAlign": "top" },

    { "type": "text", "id": "footer1", "x": 80, "y": 880, "width": 1280, "height": 25, "text": "⚠ marks where the agent process is intentionally isolated from credentials and the public internet — even if compromised.", "fontSize": 13, "fontFamily": 1, "strokeColor": "#000000", "textAlign": "center", "verticalAlign": "top" }

