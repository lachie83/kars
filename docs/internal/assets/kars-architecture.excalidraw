    { "type": "text", "id": "cluster_tag_t", "x": 100, "y": 138, "width": 140, "height": 18, "text": "AKS CLUSTER", "fontSize": 14, "fontFamily": 1, "strokeColor": "#ffffff", "textAlign": "center", "verticalAlign": "middle", "containerId": "cluster_tag" },

