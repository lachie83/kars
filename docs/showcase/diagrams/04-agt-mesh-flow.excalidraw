{
  "type": "excalidraw",
  "version": 2,
  "source": "claude",
  "elements": [
    {
      "type": "text",
      "id": "title",
      "x": 100,
      "y": 80,
      "width": 1000,
      "height": 80,
      "text": "Mesh",
      "fontSize": 72,
      "fontFamily": 2,
      "strokeColor": "#000000",
      "textAlign": "left",
      "verticalAlign": "top"
    },
    {
      "type": "text",
      "id": "subtitle",
      "x": 100,
      "y": 180,
      "width": 1000,
      "height": 40,
      "text": "Signal Protocol between agents.  No broker sees plaintext.",
      "fontSize": 24,
      "fontFamily": 2,
      "strokeColor": "#495057",
      "textAlign": "left",
      "verticalAlign": "top"
    },
    {
      "type": "ellipse",
      "id": "a",
      "x": 140,
      "y": 380,
      "width": 200,
      "height": 200,
      "strokeColor": "#0c8599",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "boundElements": [{ "type": "text", "id": "a_text" }]
    },
    {
      "type": "text",
      "id": "a_text",
      "x": 140,
      "y": 466,
      "width": 200,
      "height": 28,
      "text": "A",
      "fontSize": 48,
      "fontFamily": 2,
      "strokeColor": "#000000",
      "containerId": "a",
      "textAlign": "center",
      "verticalAlign": "middle"
    },
    {
      "type": "rectangle",
      "id": "relay",
      "x": 500,
      "y": 380,
      "width": 200,
      "height": 200,
      "strokeColor": "#0c8599",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "roundness": { "type": 3 },
      "boundElements": [{ "type": "text", "id": "relay_text" }]
    },
    {
      "type": "text",
      "id": "relay_text",
      "x": 500,
      "y": 466,
      "width": 200,
      "height": 28,
      "text": "relay",
      "fontSize": 22,
      "fontFamily": 2,
      "strokeColor": "#000000",
      "containerId": "relay",
      "textAlign": "center",
      "verticalAlign": "middle"
    },
    {
      "type": "ellipse",
      "id": "b",
      "x": 860,
      "y": 380,
      "width": 200,
      "height": 200,
      "strokeColor": "#0c8599",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "boundElements": [{ "type": "text", "id": "b_text" }]
    },
    {
      "type": "text",
      "id": "b_text",
      "x": 860,
      "y": 466,
      "width": 200,
      "height": 28,
      "text": "B",
      "fontSize": 48,
      "fontFamily": 2,
      "strokeColor": "#000000",
      "containerId": "b",
      "textAlign": "center",
      "verticalAlign": "middle"
    },
    {
      "type": "arrow",
      "id": "arr_a_relay",
      "x": 340,
      "y": 480,
      "width": 160,
      "height": 0,
      "points": [[0, 0], [160, 0]],
      "strokeColor": "#0c8599",
      "strokeWidth": 2,
      "startBinding": { "elementId": "a", "focus": 0, "gap": 1 },
      "endBinding": { "elementId": "relay", "focus": 0, "gap": 1 }
    },
    {
      "type": "arrow",
      "id": "arr_relay_b",
      "x": 700,
      "y": 480,
      "width": 160,
      "height": 0,
      "points": [[0, 0], [160, 0]],
      "strokeColor": "#0c8599",
      "strokeWidth": 2,
      "startBinding": { "elementId": "relay", "focus": 0, "gap": 1 },
      "endBinding": { "elementId": "b", "focus": 0, "gap": 1 }
    },
    {
      "type": "text",
      "id": "footer",
      "x": 100,
      "y": 680,
      "width": 1000,
