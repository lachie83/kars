{
  "name": "@kars-runtime/cli",
  "version": "0.1.7",
  "description": "Enterprise-grade runtime for running OpenClaw AI assistants safely on Azure",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/Azure/kars.git"
  },
  "bin": {
    "kars": "./dist/index.js"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "scripts": {
    "build": "tsc && chmod +x dist/index.js && cp -r profiles dist/profiles && node scripts/bundle-deploy-assets.mjs",
    "dev": "tsx watch src/index.ts",
    "lint": "oxlint .",
    "format": "oxfmt .",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@azure/identity": "^4.0.0",
    "@azure/keyvault-secrets": "^4.8.0",
    "blessed": "^0.1.81",
    "chalk": "^5.3.0",
    "commander": "^13.0.0",
    "execa": "^9.0.0",
    "inquirer": "^12.0.0",
    "node-pty": "^1.2.0-beta.12",
    "ora": "^8.0.0",
    "yaml": "^2.6.0"
  },
  "devDependencies": {
    "@types/blessed": "^0.1.27",
    "@types/node": "^22.0.0",
    "oxlint": "^0.16.0",
    "tsdown": "^0.21.7",
    "tsx": "^4.22.4",
    "typescript": "^5.7.0",
    "vitest": "^4.1.8"
  },
  "overrides": {
    "uuid": "^14.0.0",
    "xml2js": "^0.6.2",
    "lodash": "^4.17.24"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "keywords": [
    "azure",
    "openClaw",
    "ai",
    "agent",
    "sandbox",
    "security",
    "aks",
    "kubernetes"
  ],
  "publishConfig": {
    "access": "public"
  }
}
