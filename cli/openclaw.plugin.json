{
  "id": "azureclaw",
  "name": "AzureClaw",
  "version": "0.2.0",
  "description": "Secure AI agent runtime on Azure — sandboxed OpenClaw with Azure AI Foundry and Rust inference router",
  "skills": [
    "skills/foundry-memory",
    "skills/foundry-knowledge",
    "skills/foundry-web-search",
    "skills/foundry-code",
    "skills/foundry-agents",
    "skills/foundry-conversations",
    "skills/foundry-evaluations",
    "skills/foundry-deployments",
    "skills/agt-governance"
  ],
  "configSchema": {
    "type": "object",
    "properties": {
      "endpoint": {
        "type": "string",
        "description": "Azure OpenAI endpoint (e.g. https://your-resource.openai.azure.com)"
      },
      "model": {
        "type": "string",
        "description": "Default Azure OpenAI model deployment name",
        "default": "gpt-4.1"
      },
      "sandboxName": {
        "type": "string",
        "description": "Name for the sandbox",
        "default": "dev-agent"
      }
    },
    "additionalProperties": false
  }
}
