# Dev-mode inference-router image.
#
# Differs from the canonical distroless Dockerfile by using
# mcr.microsoft.com/azurelinux/base/core:3.0 (non-distroless) so the
# `egress-guard` init container — which runs `sh -c "iptables ..."`
# — actually has `sh` and `iptables` to invoke.
#
# The distroless prod image lacks both; CI installs iptables into
# the runtime image via tdnf before COPYing the binary (see the
# multistage variant). For local kind clusters we skip the heavy
# multistage cargo build by reusing the pre-staged binary from
# bin/<arch>/ and only flipping the base image. Same binary, looser
# (but functional) base.
ARG AZURELINUX_BASE=mcr.microsoft.com/azurelinux/base/core:3.0
ARG VERSION=0.1.0
ARG BIN_PATH_PREFIX=bin
ARG TARGETARCH

FROM ${AZURELINUX_BASE}
ARG VERSION
ARG BIN_PATH_PREFIX
ARG TARGETARCH

# iptables for the egress-guard init container; ca-certificates for
# TLS to Foundry; shadow-utils so we can useradd a non-root user;
# tdnf clean keeps the final image small.
RUN tdnf install -y iptables ca-certificates shadow-utils && tdnf clean all && \
    groupadd -g 1000 router && useradd -u 1000 -g router -s /sbin/nologin router

COPY ${BIN_PATH_PREFIX}/${TARGETARCH}/kars-inference-router /usr/local/bin/kars-inference-router

USER 1000:1000
EXPOSE 8443
ENTRYPOINT ["/usr/local/bin/kars-inference-router"]
