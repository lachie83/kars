{
  "id": "kars-mesh",
  "name": "Kars Mesh",
  "version": "0.1.0",
  "description": "Connect to Kars for secure cloud offload, handoff, and inter-agent communication via E2E encrypted AgentMesh.",
  "author": "Kars",
  "skills": [],
  "configSchema": {
    "relay_url": {
      "type": "string",
      "description": "AgentMesh relay URL (auto-set on pairing)"
    },
    "registry_url": {
      "type": "string",
      "description": "AgentMesh registry URL (auto-set on pairing)"
    },
    "identity_path": {
      "type": "string",
      "default": "~/.kars/identity.json",
      "description": "Path to mesh identity file"
    }
  }
}
