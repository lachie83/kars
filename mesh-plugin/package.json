{
  "name": "@azureclaw/mesh",
  "version": "0.1.0",
  "description": "Connect any OpenClaw agent to AzureClaw for secure cloud offload and inter-agent communication",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "openclaw": {
    "extensions": [
      "./dist/index.js"
    ]
  },
  "files": [
    "dist",
    "skills",
    "openclaw.plugin.json",
    "README.md"
  ],
  "scripts": {
    "build": "tsc && cp -r skills dist/skills && cp openclaw.plugin.json dist/",
    "prepare": "tsc && cp -r skills dist/skills && cp openclaw.plugin.json dist/",
    "test": "vitest run",
    "lint": "oxlint src/",
    "typecheck": "tsc --noEmit",
    "sync:nemoclaw": "npm run build && NEMOCLAW_PATH=\"${NEMOCLAW_PATH:-${HOME}/.nemoclaw/source}\" bash scripts/patch-nemoclaw.sh",
    "patch:nemoclaw": "bash scripts/patch-nemoclaw.sh",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "openclaw",
    "azureclaw",
    "agentmesh",
    "cloud-offload",
    "e2e-encryption",
    "federation"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/AzureClaw/azureclaw.git",
    "directory": "mesh-plugin"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@microsoft/agent-governance-sdk": "^3.5.0",
    "ws": "^8.18"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "@types/ws": "^8",
    "typescript": "^5.7",
    "vitest": "^3.2"
  }
}
