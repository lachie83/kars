    "directory": "mesh-plugin"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "ws": "^8.18"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "@types/ws": "^8",
    "typescript": "^5.7",
    "vitest": "^3.2"
  }
}
