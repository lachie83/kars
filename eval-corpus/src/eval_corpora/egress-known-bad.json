{
  "schemaVersion": "v1",
  "name": "egress-known-bad",
  "cases": [
    {
      "id": "egress-001-link-local",
      "tags": ["egress", "imds"],
      "scenario": {
        "kind": "EgressConnect",
        "host": "169.254.169.254",
        "port": 80
      },
      "expect": {
        "decision": "Blocked",
        "byPolicyKind": "EgressAllowlist",
        "reasonContains": "not in allowlist"
      }
    },
    {
      "id": "egress-002-cluster-internal",
      "tags": ["egress", "lateral"],
      "scenario": {
