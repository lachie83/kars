{
  "name": "@azureclaw/runtime-openclaw",
  "version": "0.1.0-alpha.1",
  "description": "AzureClaw runtime adapter for OpenClaw — loaded as an OpenClaw plugin inside the sandbox pod",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/Azure/azureclaw.git"
  },
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "openclaw": {
    "extensions": [
      "./dist/index.js"
    ]
  },
  "files": [
    "dist",
    "openclaw.plugin.json"
  ],
  "type": "module",
  "scripts": {
    "build": "tsc",
    "dev": "tsx watch src/index.ts",
    "lint": "oxlint .",
    "format": "oxfmt .",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@agentmesh/sdk": "^0.1.2",
    "commander": "^13.0.0"
  },
  "optionalDependencies": {
    "@microsoft/agent-governance-sdk": "^3.5.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "oxlint": "^0.16.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "publishConfig": {
    "access": "public"
  }
}
