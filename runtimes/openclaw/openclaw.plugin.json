{
  "id": "kars",
  "name": "kars",
  "version": "0.2.0",
  "description": "Secure AI agent runtime on Azure — sandboxed OpenClaw with Azure AI Foundry and Rust inference router",
  "activation": {
    "onStartup": true
  },
  "enabledByDefault": true,
  "contracts": {
    "tools": [
      "kars_discover",
      "kars_spawn",
      "kars_spawn_list",
      "kars_spawn_status",
      "kars_spawn_destroy",
      "kars_mesh_send",
      "kars_mesh_inbox",
      "kars_mesh_await",
      "kars_mesh_transfer_file",
      "kars_handoff_request",
      "kars_handoff_confirm",
      "kars_handoff_status",
      "http_fetch",
      "foundry_code_execute",
      "foundry_image_generation",
      "foundry_web_search",
      "foundry_file_search",
      "foundry_memory",
      "foundry_conversations",
      "foundry_evaluations",
      "foundry_deployments",
      "foundry_agents",
      "foundry_download_file",
      "telegram_status"
    ]
  },
  "skills": [
    "skills/foundry-memory",
    "skills/foundry-knowledge",
    "skills/foundry-web-search",
    "skills/foundry-code",
    "skills/foundry-agents",
    "skills/foundry-conversations",
    "skills/foundry-evaluations",
    "skills/foundry-deployments",
    "skills/agt-governance",
    "skills/kars-spawn"
  ],
  "configSchema": {
    "type": "object",
    "properties": {
      "endpoint": {
        "type": "string",
        "description": "Azure OpenAI endpoint (e.g. https://your-resource.openai.azure.com)"
      },
      "model": {
        "type": "string",
        "description": "Default Azure OpenAI model deployment name",
        "default": "gpt-4.1"
      },
      "sandboxName": {
        "type": "string",
        "description": "Name for the sandbox",
        "default": "dev-agent"
      }
    },
    "additionalProperties": false
  }
}
