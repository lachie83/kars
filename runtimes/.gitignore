# Built AGT-Python wheels (regenerated from upstream by build-agt-wheels.sh)
wheels/*.whl
wheels/*.tar.gz

# Python build artifacts
**/__pycache__/
**/*.egg-info/
**/.pytest_cache/
**/build/
**/dist/

# Per-invocation venv used by build-agt-wheels.sh to install the
# `build` package without touching the host site-packages (PEP 668).
.builder-venv/
.agt-sha
